{
  "name": "@adens/wanie",
  "version": "1.3.1",
  "description": "Wanie is an AI messaging CRM for WhatsApp, Telegram, and external apps.",
  "license": "MIT",
  "author": "asepindrak <asepindrakurniawan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asepindrak/wanie.git"
  },
  "homepage": "https://github.com/asepindrak/wanie#readme",
  "bugs": {
    "url": "https://github.com/asepindrak/wanie/issues"
  },
  "preferGlobal": true,
  "keywords": [
    "wanie",
    "cli",
    "whatsapp",
    "whatsapp-api",
    "whatsapp-gateway",
    "crm",
    "crm-automation",
    "ai-crm",
    "ai-agent",
    "telegram-bot",
    "messaging-gateway",
    "webhook",
    "knowledge-base",
    "auto-reply",
    "express",
    "nextjs",
    "socket.io",
    "prisma"
  ],
  "bin": {
    "wanie": "bin/openwa.js",
    "openwa": "bin/openwa.js"
  },
  "scripts": {
    "dev": "nodemon --watch server --watch bin --ext js --exec \"node bin/openwa.js --dev\"",
    "start": "node bin/openwa.js",
    "pack": "npm run build && npm pack",
    "build": "node ./node_modules/prisma/build/index.js generate --schema prisma/schema.prisma && npm run build:web",
    "build:web": "node ./node_modules/next/dist/bin/next build web",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "prisma:push": "node ./node_modules/prisma/build/index.js db push --schema prisma/schema.prisma",
    "postinstall": "node ./node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "publish": "npm publish --access=public",
    "prepublishOnly": "npm run build",
    "release:patch": "npm run build && npm version patch && npm publish --access=public",
    "release:minor": "npm run build && npm version minor && npm publish --access=public",
    "release:major": "npm run build && npm version major && npm publish --access=public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.2",
    "next": "^15.2.4",
    "node-fetch": "^2.7.0",
    "open": "^10.1.0",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "prisma": "^6.6.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "telegraf": "^4.16.3",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "^1.34.7",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
