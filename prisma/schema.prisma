generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../storage/database/openwa.db"
}

enum SessionState {
  connecting
  ready
  disconnected
  error
}

enum TransportType {
  mock
  wwebjs
  telegram
  whatsapp_cloud
}

enum MessageType {
  text
  image
  video
  audio
  document
  sticker
}

enum DeliveryStatus {
  sent
  delivered
  read
}

enum MessageDirection {
  inbound
  outbound
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  passwordHash         String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  contacts             Contact[]
  chats                Chat[]
  sessions             WhatsappSession[]
  mediaFiles           MediaFile[]
  apiKeys              ApiKey[]
  aiProviders          AiProvider[]
  terminalCommands     TerminalCommand[]
  userSetting          UserSetting?
  crmAiSetting         CrmAiSetting?
  crmSessionSettings   CrmSessionAiSetting[]
  crmChatSettings      CrmChatAiSetting[]
  crmAutomationLogs    CrmAutomationLog[]
  knowledgeDocuments   KnowledgeDocument[]
  knowledgeChunks      KnowledgeChunk[]
  webhookDeliveryLogs  WebhookDeliveryLog[]
  outboundDeliveryJobs OutboundDeliveryJob[]

  @@map("users")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  last4      String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("api_keys")
}

model WhatsappSession {
  id                String                @id @default(cuid())
  userId            String
  name              String
  phoneNumber       String?
  status            SessionState          @default(disconnected)
  qrCode            String?
  transportType     TransportType         @default(mock)
  lastError         String?
  lastHealthCheckAt DateTime?
  lastSeenAt        DateTime?
  reconnectAttempts Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats             Chat[]
  messages          Message[]
  contacts          Contact[]
  crmAiSettings     CrmSessionAiSetting[]

  @@index([userId])
  @@map("whatsapp_sessions")
}

model Contact {
  id                 String           @id @default(cuid())
  userId             String
  sessionId          String?
  externalId         String
  displayName        String
  persona            String?
  avatarUrl          String?
  lastMessagePreview String?
  lastMessageAt      DateTime?
  unreadCount        Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session            WhatsappSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  chats              Chat[]

  @@unique([userId, externalId])
  @@map("contacts")
}

model Chat {
  id                  String               @id @default(cuid())
  userId              String
  sessionId           String?
  contactId           String
  title               String
  pinnedAt            DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  session             WhatsappSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  contact             Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages            Message[]
  crmAiSetting        CrmChatAiSetting?
  crmAutomationLogs   CrmAutomationLog[]
  webhookDeliveryLogs WebhookDeliveryLog[]

  @@unique([userId, contactId])
  @@index([userId, updatedAt])
  @@map("chats")
}

model MediaFile {
  id                    String    @id @default(cuid())
  userId                String
  fileName              String
  originalName          String
  mimeType              String
  size                  Int
  relativePath          String
  transcriptionText     String?
  transcriptionProvider String?
  transcriptionModel    String?
  transcribedAt         DateTime?
  createdAt             DateTime  @default(now())
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages              Message[]

  @@index([userId])
  @@map("media_files")
}

model Message {
  id                  String               @id @default(cuid())
  chatId              String
  sessionId           String?
  mediaFileId         String?
  replyToId           String?
  externalMessageId   String?
  sender              String
  receiver            String
  body                String?
  type                MessageType          @default(text)
  direction           MessageDirection
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  chat                Chat                 @relation(fields: [chatId], references: [id], onDelete: Cascade)
  session             WhatsappSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  mediaFile           MediaFile?           @relation(fields: [mediaFileId], references: [id], onDelete: SetNull)
  replyTo             Message?             @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies             Message[]            @relation("MessageReplies")
  statuses            MessageStatus[]
  webhookDeliveryLogs WebhookDeliveryLog[]
  outboundDeliveryJob OutboundDeliveryJob?

  @@index([chatId, createdAt])
  @@index([externalMessageId])
  @@map("messages")
}

model MessageStatus {
  id        String         @id @default(cuid())
  messageId String
  status    DeliveryStatus
  createdAt DateTime       @default(now())
  message   Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@map("message_status")
}

model OutboundDeliveryJob {
  id            String    @id @default(cuid())
  userId        String
  messageId     String    @unique
  transport     String
  status        String    @default("queued")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  nextAttemptAt DateTime  @default(now())
  lastError     String?
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message       Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId, status, nextAttemptAt])
  @@index([status, nextAttemptAt])
  @@map("outbound_delivery_jobs")
}

model AiProvider {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  name      String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_providers")
}

enum TerminalCommandStatus {
  pending
  approved
  denied
  running
  completed
  failed
}

enum TerminalApprovalMode {
  auto
  manual
}

model TerminalCommand {
  id           String                @id @default(cuid())
  userId       String
  command      String
  cwd          String?
  approvalMode TerminalApprovalMode  @default(manual)
  status       TerminalCommandStatus @default(pending)
  requestedAt  DateTime              @default(now())
  executedAt   DateTime?
  result       Json?
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("terminal_commands")
}

// Per-user persistent settings. Kept separate from User to avoid
// risky modifications to the existing users table and ease migrations.
model UserSetting {
  id                             String   @id @default(cuid())
  userId                         String   @unique
  autoApproveAllTerminalCommands Boolean  @default(false)
  defaultAiProviderId            String?
  defaultAiModel                 String?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model CrmAiSetting {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  defaultMode                 String   @default("draft")
  embeddingProviderId         String?
  embeddingModel              String?
  transcriptionProviderId     String?
  transcriptionModel          String?
  similarityThreshold         Float    @default(0.72)
  maxChunks                   Int      @default(6)
  cooldownSeconds             Int      @default(180)
  adminPauseSeconds           Int      @default(1800)
  maxAutoRepliesPerChatPerDay Int      @default(20)
  assistantName               String   @default("OpenWA CRM Assistant")
  businessName                String?
  persona                     String?
  agentInstructions           String?
  fallbackMessage             String   @default("Terima kasih, pesan Anda akan dibantu admin kami.")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("crm_ai_settings")
}

model CrmSessionAiSetting {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  mode      String   @default("inherit")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session WhatsappSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([userId])
  @@map("crm_session_ai_settings")
}

model CrmChatAiSetting {
  id          String    @id @default(cuid())
  userId      String
  chatId      String    @unique
  mode        String    @default("inherit")
  pausedUntil DateTime?
  pauseReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
  @@index([userId])
  @@map("crm_chat_ai_settings")
}

model CrmAutomationLog {
  id                String   @id @default(cuid())
  userId            String
  chatId            String
  mode              String
  action            String
  reason            String?
  inboundMessageId  String?
  outboundMessageId String?
  draft             String?
  sources           Json?
  metadata          Json?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([userId, chatId, createdAt])
  @@index([userId, action, createdAt])
  @@map("crm_automation_logs")
}

model WebhookDeliveryLog {
  id             String    @id @default(cuid())
  userId         String
  chatId         String?
  messageId      String?
  url            String
  status         String    @default("pending")
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  nextAttemptAt  DateTime  @default(now())
  payload        Json
  responseStatus Int?
  responseBody   String?
  error          String?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat    Chat?    @relation(fields: [chatId], references: [id], onDelete: SetNull)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([status, nextAttemptAt])
  @@index([userId, chatId, createdAt])
  @@map("webhook_delivery_logs")
}

model KnowledgeDocument {
  id           String   @id @default(cuid())
  userId       String
  title        String
  fileName     String
  originalName String
  mimeType     String
  size         Int
  relativePath String
  status       String   @default("processing")
  error        String?
  textLength   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([userId, createdAt])
  @@index([userId, originalName])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id             String   @id @default(cuid())
  userId         String
  documentId     String
  content        String
  embedding      Json?
  embeddingModel String?
  tokenCount     Int?
  chunkIndex     Int
  metadata       Json?
  createdAt      DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([userId, documentId])
  @@map("knowledge_chunks")
}
