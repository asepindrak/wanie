generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../storage/database/openwa.db"
}

enum SessionState {
  connecting
  ready
  disconnected
  error
}

enum TransportType {
  mock
  wwebjs
  telegram
}

enum MessageType {
  text
  image
  video
  audio
  document
  sticker
}

enum DeliveryStatus {
  sent
  delivered
  read
}

enum MessageDirection {
  inbound
  outbound
}

model User {
  id                 String                @id @default(cuid())
  name               String
  email              String                @unique
  passwordHash       String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  contacts           Contact[]
  chats              Chat[]
  sessions           WhatsappSession[]
  mediaFiles         MediaFile[]
  apiKeys            ApiKey[]
  aiProviders        AiProvider[]
  terminalCommands   TerminalCommand[]
  userSetting        UserSetting?
  crmAiSetting       CrmAiSetting?
  crmSessionSettings CrmSessionAiSetting[]
  crmChatSettings    CrmChatAiSetting[]
  crmAutomationLogs  CrmAutomationLog[]
  knowledgeDocuments KnowledgeDocument[]
  knowledgeChunks    KnowledgeChunk[]

  @@map("users")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  last4      String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("api_keys")
}

model WhatsappSession {
  id            String                @id @default(cuid())
  userId        String
  name          String
  phoneNumber   String?
  status        SessionState          @default(disconnected)
  qrCode        String?
  transportType TransportType         @default(mock)
  lastError     String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats         Chat[]
  messages      Message[]
  contacts      Contact[]
  crmAiSettings CrmSessionAiSetting[]

  @@index([userId])
  @@map("whatsapp_sessions")
}

model Contact {
  id                 String           @id @default(cuid())
  userId             String
  sessionId          String?
  externalId         String
  displayName        String
  persona            String?
  avatarUrl          String?
  lastMessagePreview String?
  lastMessageAt      DateTime?
  unreadCount        Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session            WhatsappSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  chats              Chat[]

  @@unique([userId, externalId])
  @@map("contacts")
}

model Chat {
  id                String             @id @default(cuid())
  userId            String
  sessionId         String?
  contactId         String
  title             String
  pinnedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  session           WhatsappSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  contact           Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages          Message[]
  crmAiSetting      CrmChatAiSetting?
  crmAutomationLogs CrmAutomationLog[]

  @@unique([userId, contactId])
  @@index([userId, updatedAt])
  @@map("chats")
}

model MediaFile {
  id           String    @id @default(cuid())
  userId       String
  fileName     String
  originalName String
  mimeType     String
  size         Int
  relativePath String
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([userId])
  @@map("media_files")
}

model Message {
  id                String           @id @default(cuid())
  chatId            String
  sessionId         String?
  mediaFileId       String?
  replyToId         String?
  externalMessageId String?
  sender            String
  receiver          String
  body              String?
  type              MessageType      @default(text)
  direction         MessageDirection
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  chat              Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade)
  session           WhatsappSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  mediaFile         MediaFile?       @relation(fields: [mediaFileId], references: [id], onDelete: SetNull)
  replyTo           Message?         @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies           Message[]        @relation("MessageReplies")
  statuses          MessageStatus[]

  @@index([chatId, createdAt])
  @@map("messages")
}

model MessageStatus {
  id        String         @id @default(cuid())
  messageId String
  status    DeliveryStatus
  createdAt DateTime       @default(now())
  message   Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@map("message_status")
}

model AiProvider {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  name      String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_providers")
}

enum TerminalCommandStatus {
  pending
  approved
  denied
  running
  completed
  failed
}

enum TerminalApprovalMode {
  auto
  manual
}

model TerminalCommand {
  id           String                @id @default(cuid())
  userId       String
  command      String
  cwd          String?
  approvalMode TerminalApprovalMode  @default(manual)
  status       TerminalCommandStatus @default(pending)
  requestedAt  DateTime              @default(now())
  executedAt   DateTime?
  result       Json?
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("terminal_commands")
}

// Per-user persistent settings. Kept separate from User to avoid
// risky modifications to the existing users table and ease migrations.
model UserSetting {
  id                             String   @id @default(cuid())
  userId                         String   @unique
  autoApproveAllTerminalCommands Boolean  @default(false)
  defaultAiProviderId            String?
  defaultAiModel                 String?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model CrmAiSetting {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  defaultMode                 String   @default("draft")
  embeddingProviderId         String?
  embeddingModel              String?
  similarityThreshold         Float    @default(0.72)
  maxChunks                   Int      @default(6)
  cooldownSeconds             Int      @default(90)
  maxAutoRepliesPerChatPerDay Int      @default(20)
  persona                     String?
  fallbackMessage             String   @default("Terima kasih, pesan Anda akan dibantu admin kami.")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("crm_ai_settings")
}

model CrmSessionAiSetting {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  mode      String   @default("inherit")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session WhatsappSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([userId])
  @@map("crm_session_ai_settings")
}

model CrmChatAiSetting {
  id        String   @id @default(cuid())
  userId    String
  chatId    String   @unique
  mode      String   @default("inherit")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
  @@index([userId])
  @@map("crm_chat_ai_settings")
}

model CrmAutomationLog {
  id                String   @id @default(cuid())
  userId            String
  chatId            String
  mode              String
  action            String
  reason            String?
  inboundMessageId  String?
  outboundMessageId String?
  draft             String?
  sources           Json?
  metadata          Json?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([userId, chatId, createdAt])
  @@index([userId, action, createdAt])
  @@map("crm_automation_logs")
}

model KnowledgeDocument {
  id           String   @id @default(cuid())
  userId       String
  title        String
  fileName     String
  originalName String
  mimeType     String
  size         Int
  relativePath String
  status       String   @default("processing")
  error        String?
  textLength   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([userId, createdAt])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id             String   @id @default(cuid())
  userId         String
  documentId     String
  content        String
  embedding      Json?
  embeddingModel String?
  tokenCount     Int?
  chunkIndex     Int
  metadata       Json?
  createdAt      DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([userId, documentId])
  @@map("knowledge_chunks")
}
